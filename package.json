    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.7.0",
    "electronmon": "^2.0.3",
    "eslint": "^9",
